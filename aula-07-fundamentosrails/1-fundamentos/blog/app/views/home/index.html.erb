<div class="container">
        <h2 style="text-align:center; font-size: 1.5rem;">Posts</h2>
    <hr>
    <ul class="list-group text-center">
        <%@posts.each do |post|%>
            <li class="list-group-item">
                <%= post[:title]%> - <%= post[:body]%>
            </li>
        <%end%>
    </ul>
    <hr>
    <p style="text-align:center; font-size: 1.5rem;"><%= link_to "Student", student_path %></p>
</div>